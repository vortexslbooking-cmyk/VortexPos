{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vortexPOS",
  "version": "2.1.0",
  "identifier": "es.vortex.pos",
  "build": {
    "frontendDist": "../www"
  },
  "app": {
    "windows": [
      {
        "title": "vortexPOS — Sistema de comandas",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Spanish"],
        "displayLanguageSelector": false
      }
    }
  }
}
